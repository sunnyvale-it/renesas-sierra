# ==============================================================================
# QEMU VM & Hardware Replication Architecture Configuration
# ==============================================================================
# This configuration file is read by both launch.sh (macOS/Linux) and launch.ps1 
# (Windows) to orchestrate the QEMU environment.

# ------------------------------------------------------------------------------
# VM Instance Properties
# ------------------------------------------------------------------------------
VM_NAME="renesas-sierra-vm"
VM_DISK="disk.qcow2"
VM_DISK_SIZE="20G"
VM_MEM="4096"        # Memory in Megabytes
VM_CPUS="4"          # Virtual CPU cores (x64)

# ------------------------------------------------------------------------------
# Emulated Host Controller (Renesas uPD720202 compatible)
# ------------------------------------------------------------------------------
# nec-usb-xhci matches the NEC/Renesas uPD720200 controller, sharing the same 
# driver architecture. This is highly compatible with guest USB 3.0 requirements.
USB_CONTROLLER_TYPE="nec-usb-xhci"
USB_CONTROLLER_ID="xhci0"

# ------------------------------------------------------------------------------
# Sierra Wireless EM7590 LTE Modem USB Configuration
# ------------------------------------------------------------------------------
# Defines the vendor and product ID of the Sierra Wireless EM7590 module.
# Default Vendor ID: 0x1199 (Sierra Wireless, Inc.)
# Default Product ID: 0xc081 (EM7590 standard USB composition)
MODEM_VENDOR_ID="0x1199"
MODEM_PRODUCT_ID="0xc081"

# ------------------------------------------------------------------------------
# Software Emulation & Mock Mode Settings
# ------------------------------------------------------------------------------
# Set to "true" to emulate the entire architecture in software. 
# Set to "false" to attempt physical hardware USB passthrough.
MOCK_MODE="true"

# Host TCP port for the mock modem serial daemon to communicate with QEMU
MOCK_SERIAL_PORT="4444"
